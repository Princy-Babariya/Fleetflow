# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# For local MongoDB:
MONGO_URI=mongodb://localhost:27017/fleet_management

# For MongoDB Atlas (Cloud):
# MONGO_URI=mongodb+srv://your_username:your_password@cluster-name.mongodb.net/fleet_management?retryWrites=true&w=majority

# JWT Configuration
# Generate a strong secret key (min 32 characters recommended)
JWT_SECRET=your_super_secret_jwt_key_here_change_it
